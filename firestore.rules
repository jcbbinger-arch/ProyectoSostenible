rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != 'suspended' && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == "juan.codina@murciaeduca.es"
      );
    }

    function isAssistant() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != 'suspended' && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'assistant' ||
        isAdmin()
      );
    }

    function isApproved() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved' ||
        isAssistant()
      );
    }

    function isProjectMember(projectId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projectId == projectId ||
        isAssistant()
      );
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student', 'assistant'] &&
             data.status in ['pending', 'approved', 'suspended'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'code', 'createdBy']) &&
             data.id is string &&
             data.code is string &&
             data.createdBy is string;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    // Users Collection
    match /users/{uid} {
      allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        // Si es el admin principal (por email en token), tiene permiso total sobre perfiles
        (request.auth.token.email == "juan.codina@murciaeduca.es") ||
        // Si es el admin principal en el documento, nadie puede cambiar su rol o estado a algo que no sea admin/approved
        (resource.data.email == "juan.codina@murciaeduca.es" && 
         request.resource.data.role == "admin" && 
         request.resource.data.status == "approved") ||
        // Para otros usuarios
        (resource.data.email != "juan.codina@murciaeduca.es" && (
          (isOwner(uid) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status) ||
          isAdmin()
        ))
      );
      allow delete: if isAdmin() && resource.data.email != "juan.codina@murciaeduca.es";
    }

    // Projects Collection
    match /projects/{projectId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidProject(request.resource.data);
      allow update: if isApproved() && isProjectMember(projectId) && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    // Audit Logs Collection
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
